---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "关于";
const identity = {
    name: "HaxiLin",
    country: "中国",
    age: "21",
};
const skills = ["HTML", "CSS", "JavaScript", "Astro", "Writing Docs"];
const happy = true;
const finished = true;
const goal = 3;
---

<BaseLayout pageTitle={pageTitle} showTitle={false}>
    <div class="about-page">
        <section class="intro">
            <h1>关于我</h1>
            <p class="subtitle">……和我的新 Astro 网站！</p>
            <p>我正在学习 Astro 的入门教程。这是我网站上的第二个页面，也是我自己建立的第一页面！</p>
            <p>随着我完成更多教程，该站点将更新，所以请继续查看我的旅程将如何进行吧！</p>
        </section>

        <section class="info-grid">
            <div class="card">
                <h3>个人信息</h3>
                <dl>
                    <dt>姓名</dt>
                    <dd>{identity.name}</dd>
                    <dt>年龄</dt>
                    <dd>{identity.age}</dd>
                    <dt>国家</dt>
                    <dd>{identity.country}</dd>
                </dl>
            </div>

            <div class="card">
                <h3>技能</h3>
                <div class="skill-tags">
                    {skills.map((skill) => <span class="skill-tag">{skill}</span>)}
                </div>
            </div>

            <div class="card">
                <h3>学习状态</h3>
                <ul class="status-list">
                    {happy && <li>我非常乐意学习 Astro！</li>}
                    {finished && <li>我完成了这节教程！</li>}
                    {
                        goal === 3 ? (
                            <li>我的目标是在三天内完成。</li>
                        ) : (
                            <li>我的目标不是 3 天。</li>
                        )
                    }
                </ul>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .about-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
    }

    .intro {
        margin-bottom: 2.5rem;
    }

    .intro h1 {
        font-size: 2.2rem;
        margin-bottom: 0.3rem;
    }

    .subtitle {
        font-size: 1.1rem;
        margin-bottom: 1.2rem;
    }

    .intro p {
        line-height: 1.7;
        margin-bottom: 0.6rem;
    }

    .info-grid {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .card {
        border: 1px solid #d2d2d7;
        border-radius: 12px;
        padding: 1.5rem;
    }

    .card h3 {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #d2d2d7;
    }

    dl {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.5rem 1rem;
    }

    dt {
        font-weight: 600;
        color: #6b6b80;
    }

    .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .skill-tag {
        display: inline-block;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.85rem;
        border: 1px solid #0d0950;
        color: #0d0950;
    }

    html.dark .skill-tag {
        color: #e1e1e6;
        border-color: #ff9776;
    }

    .status-list {
        list-style: none;
        padding: 0;
    }

    .status-list li {
        padding: 0.4rem 0;
    }

    .status-list li::before {
        content: "✓ ";
        color: #0d0950;
    }
</style>
