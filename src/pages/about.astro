---
import BaseLayout from "../layouts/BaseLayout.astro";
import Comments from "../components/Comments.astro";
const pageTitle = "关于";
const identity = {
    name: "HaxiLin",
    country: "中国",
    age: "21",
};
const skills = ["HTML", "CSS", "JavaScript", "Astro"];
---

<BaseLayout pageTitle={pageTitle} showTitle={false}>
    <div class="about-page">
        <section class="intro">
            <h1>关于我</h1>
            <p class="narrative">苦于学业的大学生，对未来充满迷茫，但是也不是我停下探索脚步的理由</p>
            <p class="narrative">喜欢ai，喜欢探索和创造，喜欢打游戏看番，喜欢哲学，以前很喜欢看书，现在很少看了</p>
            <blockquote class="quote">一切都是随心所至，没什么毅力也没什么很强的执行力，但是偶尔还是会不顾一起闭眼就开始做，熬个通宵可能只是为了找到那行错误的代码</blockquote>
            <p class="narrative">微电子专业，好难！但是又想学，做做电路板写写程序，要是能跑通那会很开心</p>
            <p class="narrative">现在对域名，云服务器等比较感兴趣，ai时代光靠手里的这台笔记本还是不够的，将来云总会成为基础设施</p>
            <p class="narrative">想要实现终生学习，学习有痛苦的地方，但是成就感是很好的，收获知识是很快乐的</p>
            <blockquote class="quote">喜欢电子设备，想弹琴，想做音乐，想去世界各地旅游，想要读万卷书行万里路，想要练出8块腹肌（就在这里许愿吧）</blockquote>
        </section>

        <section class="info-grid">
            <div class="card">
                <h3>个人信息</h3>
                <dl>
                    <dt>姓名</dt>
                    <dd>{identity.name}</dd>
                    <dt>年龄</dt>
                    <dd>{identity.age}</dd>
                    <dt>国家</dt>
                    <dd>{identity.country}</dd>
                </dl>
            </div>

            <div class="card">
                <h3>技能</h3>
                <div class="skill-tags">
                    {
                        skills.map((skill) => (
                            <span class="skill-tag">{skill}</span>
                        ))
                    }
                </div>
            </div>
        </section>

        <Comments />
    </div>
</BaseLayout>

<style>
    .about-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
    }

    .intro {
        margin-bottom: 2.5rem;
    }

    .intro h1 {
        font-size: 2.2rem;
        margin-bottom: 1.2rem;
    }

    .intro .narrative {
        font-size: 0.95rem;
        color: var(--color-text-muted);
        line-height: 1.8;
        margin-bottom: 0.8rem;
    }

    .intro .quote {
        font-size: 1.1rem;
        font-weight: 500;
        line-height: 1.8;
        border-left: 4px solid var(--color-accent);
        padding: 1rem 1.5rem;
        margin: 1.2rem 0;
        background: var(--color-blockquote-bg);
        border-radius: 0 12px 12px 0;
        color: inherit;
        font-style: normal;
    }

    .info-grid {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .card {
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: var(--shadow-card);
    }

    .card h3 {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    dl {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.5rem 1rem;
    }

    dt {
        font-weight: 600;
        color: var(--color-text-muted);
    }

    .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .skill-tag {
        display: inline-block;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.85rem;
        border: 1px solid var(--color-border);
        color: var(--color-text);
        transition: border-color 0.2s, color 0.2s;
    }

    .skill-tag:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }
</style>
