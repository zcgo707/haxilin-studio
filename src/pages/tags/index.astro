---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPosts = await getCollection("blog");
const tags = [
    ...new Set(allPosts.map((post: any) => post.data.tags).flat()),
];
const pageTitle = "标签索引";
---

<BaseLayout pageTitle={pageTitle} showTitle={false}>
    <div class="tags-page">
        <h1>标签索引</h1>

        {tags.length === 0 ? (
            <p class="empty">暂无标签</p>
        ) : (
            <div class="tags">
                {tags.map((tag) => (
                    <a href={`/tags/${tag}`} class="tag">{tag}</a>
                ))}
            </div>
        )}
    </div>
</BaseLayout>

<style>
    .tags-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
    }

    .tags-page h1 {
        font-size: 2.2rem;
        margin-bottom: 1.5rem;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .tag {
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        border: 1px solid #d2d2d7;
        text-decoration: none;
        color: #0d0950;
        transition: border-color 0.2s, background 0.2s;
    }

    html.dark .tag {
        color: #e1e1e6;
    }

    .tag:hover {
        border-color: #0d0950;
        background: #e2e8f0;
    }

    .empty {
        color: #6b6b80;
        font-style: italic;
    }
</style>
