---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "HaxiLin Studio";
---

<BaseLayout pageTitle={pageTitle} showTitle={false}>
    <div class="home">
        <h1 class="home-title">HaxiLin Studio</h1>
        <p class="home-tagline">不折锋芒，不伪自由</p>
    </div>
</BaseLayout>

<style>
    .home {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem 3rem;
    }

    .home-title {
        font-family: "typhooncondital-12", "HongLeiXingShuJianTi-2", serif;
        font-size: 4rem;
        font-weight: normal;
        letter-spacing: 0.04em;
        margin-bottom: 0.5rem;
        line-height: 1.1;
    }

    .home-tagline {
        font-family: "HongLeiXingShuJianTi-2", serif;
        font-size: 1.5rem;
        letter-spacing: 0.15em;
        opacity: 0.9;
        color: #0d0950;
    }

    html.dark .home-tagline {
        color: #e1e1e6;
    }
</style>