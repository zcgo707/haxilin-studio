---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";

const pageTitle = "博客";
const allPosts = await getCollection("blog");
const allTags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
---

<BaseLayout pageTitle={pageTitle} showTitle={false}>
    <div class="blog-page">
        <div class="blog-header">
            <h1>博客</h1>
            <p>在这里，我将分享我的学习之旅。</p>
            <a
                class="rss-link"
                href="/rss.xml"
                target="_blank"
                rel="noopener noreferrer"
            >
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><circle cx="4" cy="20" r="3"></circle><path
                        d="M4 11a9 9 0 0 1 9 9h3a12 12 0 0 0-12-12v3zm0-7a16 16 0 0 1 16 16h3A19 19 0 0 0 4 4v3z"
                    ></path></svg
                >
                RSS
            </a>
        </div>

        {allTags.length > 0 && (
            <div class="blog-tags">
                <span class="blog-tags-label">标签：</span>
                {allTags.map((tag) => (
                    <a href={`/tags/${tag}`} class="blog-tag">{tag}</a>
                ))}
            </div>
        )}

        <div class="post-list">
            {allPosts.map((post) => (
                <PostCard post={post} />
            ))}
        </div>
    </div>
</BaseLayout>

<style>
    .blog-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
    }

    .blog-header {
        margin-bottom: 2rem;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .blog-header h1 {
        font-size: 2.2rem;
        margin-bottom: 0.3rem;
    }

    .blog-header p {
        color: var(--color-text-muted);
        width: 100%;
    }

    .blog-tags {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        padding: 0.8rem 1rem;
        border: 1px solid var(--color-border);
        border-radius: 12px;
    }

    .blog-tags-label {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        white-space: nowrap;
    }

    .blog-tag {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        border: 1px solid var(--color-border);
        color: var(--color-text);
        transition: border-color 0.2s, background 0.2s;
    }

    .blog-tag:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-card-hover-bg);
    }

    .rss-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        color: var(--color-accent);
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .rss-link:hover {
        background: var(--color-blockquote-bg);
    }

    .post-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
</style>
