---
const pathname = Astro.url.pathname;
const links = [
    { href: "/", label: "首页" },
    { href: "/about/", label: "关于" },
    { href: "/blog/", label: "博客" },
];
---

<nav id="main-menu" aria-label="主导航">
    <ul class="nav-links">
        {links.map((link) => (
            <li>
                <a
                    href={link.href}
                    aria-current={pathname === link.href ? "page" : undefined}
                >
                    {link.label}
                </a>
            </li>
        ))}
    </ul>
</nav>
