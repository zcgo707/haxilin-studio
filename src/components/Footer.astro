<style>
    footer {
        margin-top: auto;
        border-top: 1px solid #d2d2d7;
    }

    .footer-content {
        max-width: 80ch;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem;
    }

    .footer-social {
        display: flex;
        gap: 1rem;
    }

    .footer-social a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        color: #6b6b80;
        transition: color 0.2s, background 0.2s;
    }

    .footer-social a:hover {
        color: #0d0950;
        background: #e2e8f0;
    }

    .footer-copy {
        font-size: 0.85rem;
        color: #6b6b80;
    }

    html.dark footer {
        border-top-color: rgba(255, 255, 255, 0.08);
    }

    html.dark .footer-social a {
        color: rgba(255, 255, 255, 0.5);
    }

    html.dark .footer-social a:hover {
        color: #ff9776;
        background: rgba(255, 255, 255, 0.08);
    }

    html.dark .footer-copy {
        color: rgba(255, 255, 255, 0.4);
    }
</style>
